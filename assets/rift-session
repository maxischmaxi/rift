#!/bin/sh
# ═══════════════════════════════════════════════════════════════════════════
#  rift-session — Session-Wrapper für Display-Manager (SDDM, greetd, ...)
#
#  rift ist aktuell ein *nested* Compositor: er braucht einen Host-
#  Wayland-Compositor als Eltern. Dieser Wrapper startet einen minimalen
#  Host (cage oder sway) und führt rift darin aus. So erscheint rift in
#  SDDM als auswählbare Session.
#
#  Vorgehen:
#    1. Wenn $WAYLAND_DISPLAY schon gesetzt ist → rift direkt starten (nested)
#    2. Sonst: cage finden → `cage rift` (cage ist der DRM-Backend, rift läuft
#       als einzige App fullscreen darin)
#    3. Fallback: sway mit Auto-Start von rift
#    4. Wenn gar nichts da ist → Fehlermeldung
# ═══════════════════════════════════════════════════════════════════════════

set -e

RIFT_BIN="${RIFT_BIN:-rift}"

# --- Hilfsfunktion: Log --------------------------------------------------
log() { echo "[rift-session] $*" >&2; }

# --- Help ---------------------------------------------------------------
if [ "$1" = "--help" ] || [ "$1" = "-h" ]; then
    echo "rift-session — Session-Wrapper für Display-Manager (SDDM, greetd, ...)"
    echo ""
    echo " rift ist aktuell ein nested Compositor: er braucht einen Host-Wayland-Compositor."
    echo " Dieser Wrapper startet cage (oder sway) als Host und führt rift darin aus."
    echo ""
    echo " Vorgehen:"
    echo "   1. Wenn WAYLAND_DISPLAY gesetzt → rift direkt starten (nested)"
    echo "   2. Sonst: cage finden → cage rift (cage als DRM-Backend)"
    echo "   3. Fallback: sway mit Auto-Start von rift"
    echo "   4. Wenn gar nichts da ist → Fehlermeldung"
    exit 0
fi

# --- 1. Bereits in einer Wayland-Session? (Nested-in-Nested) -------------
if [ -n "$WAYLAND_DISPLAY" ]; then
    log "WAYLAND_DISPLAY=$WAYLAND_DISPLAY — starte rift nested"
    exec "$RIFT_BIN"
fi

# --- 2. cage (minimaler kiosk-compositor, ideal für rift) ---------------
if command -v cage >/dev/null 2>&1; then
    log "starte cage als Host-Compositor, rift darin"
    exec cage "$RIFT_BIN"
fi

# --- 3. sway als Fallback ------------------------------------------------
if command -v sway >/dev/null 2>&1; then
    log "cage nicht gefunden — starte sway als Host"
    # Temporäre sway-config die rift startet
    SWAY_CONF=$(mktemp /tmp/rift-sway-XXXXXX.conf)
    cat > "$SWAY_CONF" << SWEOF
# Auto-generated by rift-session
exec "$RIFT_BIN"
SWEOF
    exec sway -c "$SWAY_CONF"
fi

# --- 4. Nichts gefunden --------------------------------------------------
log "FEHLER: Weder cage noch sway gefunden."
log "rift benötigt einen Host-Wayland-Compositor im Nested-Modus."
log ""
log "Lösung:"
log "  Arch:   sudo pacman -S cage"
log "  Debian: sudo apt install cage"
log "  Fedora: sudo dnf install cage"
log ""
log "Ost rift direkt starten, wenn bereits in einer Wayland-Session:"
log "  rift"
exit 1